# ─────────────────────────────────────────────────────────────────────────────
#  Symphony × Thumbtack demo — single source of truth
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to `config.env` and fill in the four ALL-CAPS values.
# Everything else (run.sh, reset-demo.sh, WORKFLOW.md hooks, seed-linear.py)
# reads from here. Update once, changes propagate everywhere.
#
# config.env is git-ignored. NEVER commit your real Linear API key.
# ─────────────────────────────────────────────────────────────────────────────

# 1. Linear authentication.
#    Personal API key from https://linear.app/<workspace>/settings/account/security
LINEAR_API_KEY=lin_api_REPLACE_ME

# 2. Linear project to dispatch from.
#    The slugId is the random suffix in the project URL:
#    https://linear.app/your-team/project/promatch-demo-1a2b3c4d5e6f
#                                                       ^^^^^^^^^^^^
#    (Or copy the entire trailing string after `/project/`.)
LINEAR_PROJECT_SLUG=promatch-demo-REPLACE_ME

# 3. Linear team key for the team that owns this project.
#    Used by seed-linear.py when creating issues. e.g. "ENG", "TT", "DEMO".
LINEAR_TEAM_KEY=REPLACE_ME

# 4. Path to the promatch repo Symphony will dispatch agents into.
#    This MUST be a real git repo with an `origin` remote pointing at GitHub —
#    the agents push branches and open PRs against this remote.
#    Default: the bundled `promatch/` next to this file.
TARGET_REPO=$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)/promatch

# ─────────────────────────────────────────────────────────────────────────────
# Below are derived / advanced values. Most users don't need to touch these.
# ─────────────────────────────────────────────────────────────────────────────

# Where this whole demo lives. Auto-detected; override only if you move things.
SYMPHONY_DIR=$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)

# Symphony's debug verbosity. `info` is fine for demos; `debug` for debugging.
SYMPHONY_LOG_LEVEL=info

# Export them so child processes (Symphony, hooks, scripts) inherit.
export LINEAR_API_KEY LINEAR_PROJECT_SLUG LINEAR_TEAM_KEY
export TARGET_REPO SYMPHONY_DIR SYMPHONY_LOG_LEVEL
